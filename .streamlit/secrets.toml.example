# Copy this file to .streamlit/secrets.toml and fill in your values.
# Everything here is OPTIONAL — without it the app runs on local storage with a
# simulated AI draft. Add pieces as you're ready.

# ---------------------------------------------------------------------------
# 1) Real Claude AI drafts (optional)
# Get a key at https://console.anthropic.com  →  Settings  →  API Keys
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY = "sk-ant-..."

# ---------------------------------------------------------------------------
# 2) Google Sheets storage (optional) — works with a FREE personal Gmail.
#
# One-time setup:
#   a. Go to https://console.cloud.google.com and create a free project.
#   b. Enable the "Google Sheets API" and "Google Drive API" for it.
#   c. Create a Service Account, then add a JSON key. Download the JSON.
#   d. Create a normal Google Sheet in your Drive. Copy its key from the URL:
#         https://docs.google.com/spreadsheets/d/THIS_LONG_ID/edit
#   e. Click "Share" on the sheet and share it (Editor) with the service
#      account's email (the "client_email" field below).
#   f. Paste the JSON values below and set spreadsheet_key.
# ---------------------------------------------------------------------------
# spreadsheet_key = "THE_LONG_ID_FROM_YOUR_SHEET_URL"
#
# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "your-sa@your-project-id.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
# universe_domain = "googleapis.com"
